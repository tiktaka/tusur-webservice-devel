# Используем образ python с версией 3.12 в качестве основы
FROM python:3.12-slim
# Переходим в корневую директорию образа
WORKDIR /
# Копируем из проекта файл requirements.txt, который содержит все модули python, необходимые для запуска
COPY flaskapp/requirements.txt .
# Устанавливаем модули из requirements.txt с помощью pip
RUN pip install -r requirements.txt
# Копируем сам проект flaskapp в файловую систему образа и обозначаем директорию проекта как рабочую
COPY flaskapp /flaskapp
WORKDIR /flaskapp
# Обозначаем порт tcp/5000 как порт, который будет использоваться приложением для связи
EXPOSE 5000
# Указываем команду, которая будет выполняться при запуске контейнера.
# Команда запускает gunicorn с указанием, что нужно слушать порт 5000 на всех интерфейсах и запустить приложение app
CMD ["gunicorn", "-w", "4", "--bind", "0.0.0.0:5000", "wsgi:app"]